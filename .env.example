PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=github_analyzer

# Optional: raises the GitHub API rate limit for public data.
# Use a fine-grained token with no repository permissions.
GITHUB_TOKEN=

# Cache and API rate limits
CACHE_TTL=300
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
